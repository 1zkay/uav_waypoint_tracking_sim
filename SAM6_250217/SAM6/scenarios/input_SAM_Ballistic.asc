TITLE input_SAM_Ballistic.asc

//
// ballistic flight starting a 5000 m altitude  
//
OPTIONS y_scrn  y_plot 
MODULES
    environment     def,exec    
    kinematics      def,init,exec
    propulsion      def,exec
    aerodynamics    def,init,exec
    forces          def,exec
    euler           def,exec
    newton          def,init,exec
END
TIMING
    scrn_step 0.2
    plot_step 0.01
    int_step 0.001
END
VEHICLES 1
	MISSILE6 SAM
		//Initial conditions
			launch_delay 0 //Delay of vehicle launch since sim start - s module kinematics
			sbel1  0    //Initial north comp of SBEL - m  module newton
			sbel2  0    //Initial east comp of SBEL - m  module newton
			sbel3  -6000    //Initial down comp of SBEL - m  module newton
			psiblx  0    //Yawing angle of vehicle - deg  module kinematics
			thtblx  0    //Pitching angle of vehicle - deg  module kinematics
			phiblx  0    //Rolling angle of vehicle - deg  module kinematics
			alpha0x  0    //Initial angle-of-attack - deg  module newton
			beta0x  0    //Initial side slip angle - deg  module newton
			dvbe  250    //Missile speed - m/s  module newton
		//aerodynamics
			AERO_DECK   data/SAM_aero_deck.asc
			xcgref  2.5    //Vehicle reference CG aft of vehicle nose - m  module propulsion
		//propulsion
			PROP_DECK data/SAM_prop_deck.asc
	END
ENDTIME 1
STOP
