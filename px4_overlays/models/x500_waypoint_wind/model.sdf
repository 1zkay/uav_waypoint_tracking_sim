<?xml version="1.0" encoding="UTF-8"?>
<sdf version='1.9'>
  <model name='x500_waypoint_wind'>
    <include merge='true'>
      <uri>model://x500</uri>
    </include>
    <enable_wind>true</enable_wind>
    <plugin
      filename="gz-sim-odometry-publisher-system"
      name="gz::sim::systems::OdometryPublisher">
      <dimensions>3</dimensions>
    </plugin>
  </model>
</sdf>
